#!/usr/bin/env bash
set -euo pipefail

BASE_SOURCE="${CHEZMOI_BASE_SOURCE:-$HOME/git/chezmoi-base}"
PERSONAL_SOURCE="${CHEZMOI_PERSONAL_SOURCE:-$HOME/git/chezmoi-personal}"
WORK_SOURCE="${CHEZMOI_WORK_SOURCE:-$HOME/git/chezmoi-work}"
CONFIG_ROOT="${CHEZMOI_CONFIG_ROOT:-${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi-compose}"
STATE_ROOT="${CHEZMOI_STATE_ROOT:-${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi-compose}"
DESTINATION="${CHEZMOI_DESTINATION:-$HOME}"

sources_for_role() {
  case "$1" in
    personal) printf '%s\n%s\n' "$BASE_SOURCE" "$PERSONAL_SOURCE" ;;
    work) printf '%s\n%s\n' "$BASE_SOURCE" "$WORK_SOURCE" ;;
    *) printf 'unsupported role: %s\n' "$1" >&2; return 64 ;;
  esac
}

config_for_source() {
  case "$1" in
    "$BASE_SOURCE") printf '%s/base.toml\n' "$CONFIG_ROOT" ;;
    "$PERSONAL_SOURCE") printf '%s/personal.toml\n' "$CONFIG_ROOT" ;;
    "$WORK_SOURCE") printf '%s/work.toml\n' "$CONFIG_ROOT" ;;
    *) return 64 ;;
  esac
}

state_for_source() {
  case "$1" in
    "$BASE_SOURCE") printf '%s/base.boltdb\n' "$STATE_ROOT" ;;
    "$PERSONAL_SOURCE") printf '%s/personal.boltdb\n' "$STATE_ROOT" ;;
    "$WORK_SOURCE") printf '%s/work.boltdb\n' "$STATE_ROOT" ;;
    *) return 64 ;;
  esac
}

usage() {
  printf 'usage: %s <preflight|diff|verify> <personal|work>\n' "$0" >&2
  printf '       %s sync [personal|work] [--non-interactive] [--no-pull]\n' "$0" >&2
  printf '       %s apply <personal|work> <absolute-target>...\n' "$0" >&2
}

detect_role() {
  if [ -d "$PERSONAL_SOURCE" ]; then
    printf 'personal\n'
  else
    printf 'work\n'
  fi
}

run_chezmoi() {
  local source config state

  source=$1
  shift
  config=$(config_for_source "$source") || return $?
  state=$(state_for_source "$source") || return $?

  chezmoi --source "$source" --config "$config" \
    --persistent-state "$state" --destination "$DESTINATION" "$@"
}

require_selected_sources() {
  local source config

  for source in "${sources[@]}"; do
    if [ ! -d "$source" ]; then
      printf 'source directory does not exist: %s\n' "$source" >&2
      return 66
    fi

    config=$(config_for_source "$source") || return $?
    if [ ! -f "$config" ]; then
      printf 'config file does not exist: %s\n' "$config" >&2
      return 66
    fi
  done

  mkdir -p "$STATE_ROOT"
}

managed_lists_dir=

cleanup() {
  if [ -n "$managed_lists_dir" ]; then
    rm -rf "$managed_lists_dir"
  fi
}
trap cleanup EXIT

collect_managed_lists() {
  if [ -n "$managed_lists_dir" ]; then
    return 0
  fi
  mkdir -p "$STATE_ROOT"
  managed_lists_dir=$(mktemp -d "$STATE_ROOT/chezmoi-compose.XXXXXX")
  run_chezmoi "${sources[0]}" managed --include files,symlinks --path-style absolute > "$managed_lists_dir/base"
  run_chezmoi "${sources[1]}" managed --include files,symlinks --path-style absolute > "$managed_lists_dir/overlay"
}

preflight() {
  collect_managed_lists
  LC_ALL=C sort "$managed_lists_dir/base" > "$managed_lists_dir/base.sorted"
  LC_ALL=C sort "$managed_lists_dir/overlay" > "$managed_lists_dir/overlay.sorted"
  LC_ALL=C comm -12 "$managed_lists_dir/base.sorted" "$managed_lists_dir/overlay.sorted" > "$managed_lists_dir/collisions"
  if [ -s "$managed_lists_dir/collisions" ]; then
    printf 'target ownership collision:\n' >&2
    cat "$managed_lists_dir/collisions" >&2
    return 1
  fi
}

sync_pulled=()
sync_notes=()

pull_repo() {
  local repo=$1

  if [ ! -d "$repo/.git" ]; then
    sync_notes[${#sync_notes[@]}]="$repo: not a git repo, pull skipped"
    return 0
  fi
  if [ -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]; then
    sync_notes[${#sync_notes[@]}]="$repo: dirty working tree, pull skipped"
    return 0
  fi
  if git -C "$repo" pull --ff-only --quiet 2>/dev/null; then
    sync_pulled[${#sync_pulled[@]}]="$repo"
  else
    sync_notes[${#sync_notes[@]}]="$repo: pull failed (offline or diverged), continuing with local tree"
  fi
}

sync_applied=()
sync_refreshed=()
sync_skipped=()
sync_decisions=()

is_runtime_skip() {
  case "$1" in
    .claude/settings.json|.codex/config.toml) return 0 ;;
  esac
  return 1
}

cosmetic_diff() {
  local source=$1 target=$2 diff_out added removed

  diff_out=$(run_chezmoi "$source" diff -- "$target" 2>/dev/null) || return 1
  added=$(printf '%s\n' "$diff_out" | grep '^+' | grep -v '^+++' | sed 's/^+//' | tr -d '[:space:]') || true
  removed=$(printf '%s\n' "$diff_out" | grep '^-' | grep -v '^---' | sed 's/^-//' | tr -d '[:space:]') || true
  [ "$added" = "$removed" ]
}

classify_source() {
  local source=$1 status_out line code target abs plain_batch force_batch scripts_pending

  plain_batch=()
  force_batch=()
  scripts_pending=0
  status_out=$(run_chezmoi "$source" status)
  while IFS= read -r line; do
    if [ -z "$line" ]; then
      continue
    fi
    code=${line:0:2}
    target=${line:3}
    abs="$DESTINATION/$target"
    if [ "$code" = ' R' ] && [[ "$target" == .chezmoiscripts/* ]]; then
      scripts_pending=1
      continue
    fi
    if is_runtime_skip "$target"; then
      sync_skipped[${#sync_skipped[@]}]="$target"
      continue
    fi
    case "$code" in
      ' M'|' A')
        plain_batch[${#plain_batch[@]}]="$abs"
        ;;
      'M ')
        sync_refreshed[${#sync_refreshed[@]}]="$target"
        ;;
      'MM')
        if cosmetic_diff "$source" "$abs"; then
          force_batch[${#force_batch[@]}]="$abs"
        else
          sync_decisions[${#sync_decisions[@]}]="$source|$target"
        fi
        ;;
      *)
        sync_decisions[${#sync_decisions[@]}]="$source|$target"
        ;;
    esac
  done <<EOF
$status_out
EOF
  if [ "${#plain_batch[@]}" -gt 0 ]; then
    run_chezmoi "$source" apply --parent-dirs -- "${plain_batch[@]}"
    for abs in "${plain_batch[@]}"; do
      sync_applied[${#sync_applied[@]}]="$abs"
    done
  fi
  if [ "${#force_batch[@]}" -gt 0 ]; then
    run_chezmoi "$source" apply --force --parent-dirs -- "${force_batch[@]}"
    for abs in "${force_batch[@]}"; do
      sync_applied[${#sync_applied[@]}]="$abs"
    done
  fi
  if [ "$scripts_pending" -eq 1 ]; then
    run_chezmoi "$source" apply --include scripts
  fi
}

notify_decisions() {
  local count=$1

  if ! command -v osascript > /dev/null 2>&1; then
    return 0
  fi
  osascript -e "display notification \"$count file(s) need decisions - run chezmoi-sync\" with title \"chezmoi sync\"" > /dev/null 2>&1 || true
}

resolve_decisions() {
  local entry source target abs source_path choice remaining

  remaining=()
  for entry in "${sync_decisions[@]}"; do
    source=${entry%%|*}
    target=${entry#*|}
    abs="$DESTINATION/$target"
    printf '\n--- decision needed: %s (owner: %s) ---\n' "$target" "$source"
    run_chezmoi "$source" diff -- "$abs" || true
    source_path=$(run_chezmoi "$source" source-path -- "$abs" 2>/dev/null) || source_path=
    case "$source_path" in
      *.tmpl)
        printf 'templated target: import unavailable, merge manually into %s\n' "$source_path"
        printf '[o]verwrite from source / [s]kip? '
        ;;
      *)
        printf '[o]verwrite from source / [i]mport into source / [s]kip? '
        ;;
    esac
    IFS= read -r choice
    case "$choice" in
      o)
        run_chezmoi "$source" apply --force --parent-dirs -- "$abs"
        sync_applied[${#sync_applied[@]}]="$abs"
        ;;
      i)
        case "$source_path" in
          *.tmpl)
            printf 'import unavailable for templated target, skipping\n'
            remaining[${#remaining[@]}]="$entry"
            ;;
          *)
            run_chezmoi "$source" re-add -- "$abs"
            printf 'imported %s - review and commit in %s\n' "$target" "$source"
            ;;
        esac
        ;;
      *)
        remaining[${#remaining[@]}]="$entry"
        ;;
    esac
  done
  sync_decisions=()
  if [ "${#remaining[@]}" -gt 0 ]; then
    for entry in "${remaining[@]}"; do
      sync_decisions[${#sync_decisions[@]}]="$entry"
    done
  fi
}

print_summary() {
  local entry

  printf '\nchezmoi-sync summary (%s):\n' "$role"
  printf '  repos pulled: %d\n' "${#sync_pulled[@]}"
  if [ "${#sync_notes[@]}" -gt 0 ]; then
    for entry in "${sync_notes[@]}"; do
      printf '  note: %s\n' "$entry"
    done
  fi
  printf '  applied: %d\n' "${#sync_applied[@]}"
  printf '  state refreshed: %d\n' "${#sync_refreshed[@]}"
  printf '  runtime drift skipped: %d\n' "${#sync_skipped[@]}"
  printf '  decisions pending: %d\n' "${#sync_decisions[@]}"
  if [ "${#sync_decisions[@]}" -gt 0 ]; then
    for entry in "${sync_decisions[@]}"; do
      printf '    %s (owner: %s)\n' "${entry#*|}" "${entry%%|*}"
    done
  fi
}

sync_run() {
  local source

  if [ "$no_pull" -eq 0 ]; then
    for source in "${sources[@]}"; do
      pull_repo "$source"
    done
  fi
  preflight
  for source in "${sources[@]}"; do
    classify_source "$source"
  done
  if [ "${#sync_decisions[@]}" -gt 0 ] && [ "$non_interactive" -eq 0 ]; then
    resolve_decisions
  fi
  print_summary
  if [ "${#sync_decisions[@]}" -gt 0 ]; then
    if [ "$non_interactive" -eq 1 ]; then
      notify_decisions "${#sync_decisions[@]}"
    fi
    return 2
  fi
}

apply_targets_cmd() {
  local target base_batch overlay_batch

  base_batch=()
  overlay_batch=()
  for target in "${apply_targets[@]}"; do
    if LC_ALL=C grep -Fqx -- "$target" "$managed_lists_dir/base"; then
      base_batch[${#base_batch[@]}]="$target"
    elif LC_ALL=C grep -Fqx -- "$target" "$managed_lists_dir/overlay"; then
      overlay_batch[${#overlay_batch[@]}]="$target"
    else
      printf 'target not managed by base or overlay: %s\n' "$target" >&2
      return 65
    fi
  done
  if [ "${#base_batch[@]}" -gt 0 ]; then
    run_chezmoi "${sources[0]}" apply --parent-dirs -- "${base_batch[@]}"
  fi
  if [ "${#overlay_batch[@]}" -gt 0 ]; then
    run_chezmoi "${sources[1]}" apply --parent-dirs -- "${overlay_batch[@]}"
  fi
}

command=${1:-}
if [ -z "$command" ]; then
  usage
  exit 64
fi
shift

role=
non_interactive=0
no_pull=0
apply_targets=()

case "$command" in
  preflight|diff|verify)
    if [ "$#" -ne 1 ]; then
      usage
      exit 64
    fi
    role=$1
    ;;
  apply)
    if [ "$#" -lt 2 ]; then
      usage
      exit 64
    fi
    role=$1
    shift
    apply_targets=("$@")
    ;;
  sync)
    while [ "$#" -gt 0 ]; do
      case "$1" in
        personal|work) role=$1 ;;
        --non-interactive) non_interactive=1 ;;
        --no-pull) no_pull=1 ;;
        *) usage; exit 64 ;;
      esac
      shift
    done
    if [ -z "$role" ]; then
      role=$(detect_role)
    fi
    if [ ! -t 0 ]; then
      non_interactive=1
    fi
    ;;
  *)
    printf 'unsupported command: %s\n' "$command" >&2
    exit 64
    ;;
esac

selected_sources=$(sources_for_role "$role") || exit $?
sources=()
while IFS= read -r source; do
  sources[${#sources[@]}]="$source"
done <<EOF
$selected_sources
EOF

if [ "${#sources[@]}" -ne 2 ]; then
  printf 'expected exactly two sources for role: %s\n' "$role" >&2
  exit 64
fi

require_selected_sources

case "$command" in
  preflight)
    preflight
    ;;
  diff|verify)
    preflight
    for source in "${sources[@]}"; do
      run_chezmoi "$source" "$command"
    done
    ;;
  apply)
    preflight
    apply_targets_cmd
    ;;
  sync)
    sync_run
    ;;
esac
